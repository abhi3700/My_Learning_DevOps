    {
      "id": "-vamapIVFlCQRdYz3VWLz",
      "type": "text",
      "x": 1711.6943821581733,
      "y": 578.7998357767302,
      "width": 1507,
      "height": 750,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "-0q0N0inlMt4WR6DOEieC"
      ],
      "frameId": "wsRGf6vwQWlnYVpg0MDSH",
      "index": "am",
      "roundness": null,
      "seed": 1937748595,
      "version": 120,
      "versionNonce": 2017067918,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776423795696,
      "link": null,
      "locked": false,
      "text": "use anyhow::Result;\nuse base64::Engine;\nuse base64::engine::general_purpose::STANDARD;\nuse k256::pkcs8::DecodePublicKey;\nuse k256::ecdsa::VerifyingKey;\nuse sha3::{Digest, Keccak256};\n\nfn main() -> Result<()> {\n    let b64 = \"MFYwEAYHKoZIzj0CAQYFK4EEAAoDQgAEh259uE8P45UOfZ07G1PfKXzholsaE/3Y9if5wTqV1eX27oP/NDxunwOeaP1FcKy4EhZ2hZ9HA4vQYzN6nzDc6g==\";\n\n    // 1) decode DER/SPKI from AWS KMS\n    let der = STANDARD.decode(b64)?;\n\n    // 2) parse verifying key\n    let vk = VerifyingKey::from_public_key_der(&der)?;\n\n    // 3) get uncompressed pubkey: 0x04 || X || Y\n    let pubkey = vk.to_encoded_point(false);\n    let pubkey_bytes = pubkey.as_bytes();\n\n    let hex_pubkey = hex::encode(pubkey_bytes);\n    println!(\"pubkey hex: {}\", hex_pubkey);\n\n    // 4) derive Ethereum address\n    let hash = Keccak256::digest(&pubkey_bytes[1..]); // skip 0x04\n    let address = &hash[12..]; // last 20 bytes\n    println!(\"eth address: 0x{}\", hex::encode(address));\n\n    Ok(())\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "Lmwbf3Y2yNrk26nWpNdCc",
      "originalText": "use anyhow::Result;\nuse base64::Engine;\nuse base64::engine::general_purpose::STANDARD;\nuse k256::pkcs8::DecodePublicKey;\nuse k256::ecdsa::VerifyingKey;\nuse sha3::{Digest, Keccak256};\n\nfn main() -> Result<()> {\n    let b64 = \"MFYwEAYHKoZIzj0CAQYFK4EEAAoDQgAEh259uE8P45UOfZ07G1PfKXzholsaE/3Y9if5wTqV1eX27oP/NDxunwOeaP1FcKy4EhZ2hZ9HA4vQYzN6nzDc6g==\";\n\n    // 1) decode DER/SPKI from AWS KMS\n    let der = STANDARD.decode(b64)?;\n\n    // 2) parse verifying key\n    let vk = VerifyingKey::from_public_key_der(&der)?;\n\n    // 3) get uncompressed pubkey: 0x04 || X || Y\n    let pubkey = vk.to_encoded_point(false);\n    let pubkey_bytes = pubkey.as_bytes();\n\n    let hex_pubkey = hex::encode(pubkey_bytes);\n    println!(\"pubkey hex: {}\", hex_pubkey);\n\n    // 4) derive Ethereum address\n    let hash = Keccak256::digest(&pubkey_bytes[1..]); // skip 0x04\n    let address = &hash[12..]; // last 20 bytes\n    println!(\"eth address: 0x{}\", hex::encode(address));\n\n    Ok(())\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
