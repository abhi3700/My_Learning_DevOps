      "boundElements": [],
      "updated": 1776423795696,
      "link": null,
      "locked": false,
      "text": "When you create a key, it automatically creates a key pair returning\nthe DER encoded public key.\nFurther you need to extract eth address from there.\n\nCode 👇",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When you create a key, it automatically creates a key pair returning the DER encoded public key.\nFurther you need to extract eth address from there.\n\nCode 👇",
      "autoResize": false,
      "lineHeight": 1.25
    },
